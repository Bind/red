# CI-layer secrets. Consumed by GitHub Actions via `dotenvx run -f .env.ci --`.
# Decryption key: DOTENV_PRIVATE_KEY_CI (set as a repo secret in GitHub).
#
# After filling the values below, run:   dotenvx encrypt -f .env.ci
# That replaces the plaintext with ciphertext and appends the matching
# DOTENV_PRIVATE_KEY_CI into .env.keys (which is gitignored).

HCLOUD_TOKEN=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""
CLOUDFLARE_DEFAULT_ACCOUNT_ID=""

HETZNER_SSH_PUBLIC_KEY=""
HETZNER_SSH_PRIVATE_KEY=""

DEV_SERVER_IP=""
DEV_SSH_PRIVATE_KEY=""

# Anthropic key for the docs-review PR action
ANTHROPIC_API_KEY=""
