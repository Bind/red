set dotenv-load

default:
    @just --list --unsorted

install:
    bun install

run duration="30":
    AI_DAEMONS_RUN_SECONDS={{ duration }} bun run src/index.ts

dev:
    bun --watch src/index.ts

test:
    bun test

typecheck:
    bunx tsc --noEmit

lint:
    bun run lint

format:
    bun run format
