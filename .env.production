# Production service env. Decrypted at deploy time into /opt/redc/.env on the
# prod box, which docker compose reads via `env_file`.
# Decryption key: DOTENV_PRIVATE_KEY_PRODUCTION (kept ONLY on the prod box).
#
# After filling the values below, run:   dotenvx encrypt -f .env.production

# Anthropic — used by apps/triage when TRIAGE_WORKFLOW_MODE=smithers
ANTHROPIC_API_KEY=""

# Smithers bearer token (openssl rand -hex 32)
SMITHERS_API_KEY=""

# Better Auth session signer
AUTH_BETTER_AUTH_SECRET=""
# Postgres password for the auth DB
AUTH_DB_PASSWORD=""

# grs admin credentials + signing secret for bearer tokens
GIT_SERVER_ADMIN_PASSWORD=""
GIT_SERVER_AUTH_TOKEN_SECRET=""

# MinIO root password (used by both grs + wide-events collector)
MINIO_SECRET_KEY=""
