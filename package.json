{
  "name": "red",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": ["apps/*", "pkg/*", "workflows/*"],
  "bin": {
    "red": "apps/ctl/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch apps/ctl/index.ts",
    "start": "bun run apps/ctl/index.ts",
    "cli": "bun run apps/ctl/cli/index.ts",
    "claw:manual": "bun run apps/ctl/claw/manual.ts",
    "build": "turbo run build",
    "test": "bun test",
    "turbo:test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "deploy": "./infra/prod/deploy.sh"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "hono": "^4.12.12",
    "superjson": "^2.2.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@flue/cli": "^0.3.5",
    "@flue/sdk": "^0.3.5",
    "@types/bun": "latest",
    "sst": "^3",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3"
  }
}
