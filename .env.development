# Local development env. Consumed by `just up` via `dotenvx run`.
# Decryption key: DOTENV_PRIVATE_KEY_DEVELOPMENT (kept in your ~/.env.keys).
#
# After filling the values below, run:   dotenvx encrypt -f .env.development

# Optional — leave blank unless you want to exercise the triage workflow locally
ANTHROPIC_API_KEY=""
SMITHERS_API_KEY=""

# Local dev defaults for Postgres / MinIO / etc. are already set in
# infra/compose/dev.yml; override here only if you want different values.

# Dev convenience: skip MCP OAuth when running locally without a full
# auth stack. Flip to false + populate the client creds for a realistic
# end-to-end test.
MCP_DISABLE_AUTH="true"
MCP_OAUTH_CLIENT_ID=""
MCP_OAUTH_CLIENT_SECRET=""
