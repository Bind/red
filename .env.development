# Local development env. Consumed by `just up` via `dotenvx run`.
# Decryption key: DOTENV_PRIVATE_KEY_DEVELOPMENT (kept in your ~/.env.keys).
#
# After filling the values below, run:   dotenvx encrypt -f .env.development

# Local triage defaults to subscription-backed Codex via the host's
# ~/.codex auth. Switch TRIAGE_AGENT_MODE to "openai-compatible" if you
# prefer an API key through OpenRouter or another OpenAI-compatible gateway.
SMITHERS_API_KEY=""
TRIAGE_AGENT_MODE="subscription"
TRIAGE_SUBSCRIPTION_MODEL="gpt-5.3-codex"
TRIAGE_SUBSCRIPTION_REASONING_EFFORT="high"
TRIAGE_OPENAI_BASE_URL="https://openrouter.ai/api/v1"
TRIAGE_OPENAI_API_KEY=""
TRIAGE_OPENAI_MODEL="anthropic/claude-sonnet-4.5"
TRIAGE_OPENAI_PROVIDER_NAME="openrouter"
TRIAGE_OPENAI_TITLE="redc"
TRIAGE_OPENAI_REFERER=""

# Local dev defaults for Postgres / MinIO / etc. are already set in
# infra/compose/dev.yml; override here only if you want different values.

# Dev convenience: skip MCP OAuth when running locally without a full
# auth stack. Flip to false + populate the client creds for a realistic
# end-to-end test.
MCP_DISABLE_AUTH="true"
MCP_OAUTH_CLIENT_ID=""
MCP_OAUTH_CLIENT_SECRET=""
