# Preview (dev-box) service env. Decrypted at deploy time into
# /opt/redc-previews/.env, which every per-PR preview stack reads via
# `env_file` in infra/compose/preview.yml.
# Decryption key: DOTENV_PRIVATE_KEY_PREVIEW (kept ONLY on the dev box).
#
# After filling the values below, run:   dotenvx encrypt -f .env.preview

ANTHROPIC_API_KEY=""
SMITHERS_API_KEY=""

AUTH_BETTER_AUTH_SECRET=""
AUTH_DB_PASSWORD=""

GIT_SERVER_ADMIN_PASSWORD=""
GIT_SERVER_AUTH_TOKEN_SECRET=""

MINIO_SECRET_KEY=""
