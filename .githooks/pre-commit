#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

needs_repo_checks_pattern='^(apps|pkg|workflows)/|^\.github/workflows/|^(package\.json|bun\.lock|turbo\.json|justfile)$'

if echo "$staged_files" | rg -q "$needs_repo_checks_pattern"; then
  echo "pre-commit: running repo lint"
  just lint

  echo "pre-commit: running repo typecheck"
  bun run typecheck

  echo "pre-commit: running root bun test"
  bun test
else
  echo "pre-commit: skipping repo lint/typecheck/test (no staged changes in checked surfaces)"
fi

if echo "$staged_files" | rg -q '^apps/auth/'; then
  echo "pre-commit: formatting and linting apps/auth"
  (
    cd apps/auth
    bun run format
    bun run lint
  )
  git add apps/auth
fi

if echo "$staged_files" | rg -q '^apps/grs/zig/'; then
  echo "pre-commit: formatting and verifying apps/grs/zig"
  just git-server-zig-check
  git add apps/grs/zig
fi
