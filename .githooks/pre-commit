#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if echo "$staged_files" | rg -q '^(apps|pkg)/'; then
  echo "pre-commit: running root bun test"
  bun test
else
  echo "pre-commit: skipping root bun test (no staged changes under apps/ or pkg/)"
fi

if echo "$staged_files" | rg -q '^apps/auth/'; then
  echo "pre-commit: formatting and linting apps/auth"
  (
    cd apps/auth
    bun run format
    bun run lint
  )
  git add apps/auth
fi

if echo "$staged_files" | rg -q '^apps/grs/zig/'; then
  echo "pre-commit: formatting and verifying apps/grs/zig"
  just git-server-zig-check
  git add apps/grs/zig
fi
