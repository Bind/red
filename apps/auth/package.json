{
  "name": "@red/auth",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/index.ts src/server.ts src/service src/store src/util src/test",
    "format": "biome format --write src/index.ts src/server.ts src/service src/store src/util src/test"
  },
  "dependencies": {
    "@red/obs": "workspace:*",
    "@red/server": "workspace:*",
    "@better-auth/passkey": "^1.3.0",
    "@better-auth/utils": "^0.3.1",
    "better-auth": "^1.3.0",
    "jose": "^6.2.2",
    "kysely": "^0.28.12",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@levischuck/tiny-cbor": "^0.2.11",
    "@simplewebauthn/server": "^13.3.0",
    "@types/bun": "latest",
    "@types/pg": "^8.15.5"
  }
}
